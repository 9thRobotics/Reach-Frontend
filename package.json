{
  "name": "reach-frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "vite",                 // Run the local development server
    "build": "vite build",         // Build for production
    "preview": "vite preview",     // Preview production build
    "predeploy": "npm run build",  // Build before deploying
    "deploy": "gh-pages -d dist"   // Deploy to GitHub Pages
  },
  "dependencies": {
    "ethers": "^6.7.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.0.0",
    "vite": "^6.0.3",
    "gh-pages": "^5.0.0"
  }
}
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
